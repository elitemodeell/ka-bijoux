generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")       // Supabase connection pooler (pgbouncer) — usado em runtime
  directUrl = env("DIRECT_URL")        // Supabase direct connection — usado apenas para migrations
}

// ─── Admin ────────────────────────────────────────────────────────────────────

model Admin {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      AdminRole @default(ADMIN)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins")
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
}

// ─── Customer ─────────────────────────────────────────────────────────────────

model Customer {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  phone        String?
  cpf          String?   @unique
  passwordHash String
  active       Boolean   @default(true)
  pushToken    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  addresses     Address[]
  orders        Order[]
  cart          Cart?
  favorites     Favorite[]
  notifications Notification[]

  @@map("customers")
}

// ─── Address ──────────────────────────────────────────────────────────────────

model Address {
  id           String   @id @default(cuid())
  label        String?
  street       String
  number       String
  complement   String?
  neighborhood String
  city         String
  state        String
  zipCode      String
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId String
  orders     Order[]

  @@map("addresses")
}

// ─── Category ─────────────────────────────────────────────────────────────────

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  imageUrl    String?
  active      Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  parentId String?
  children Category[] @relation("CategoryHierarchy")

  products            Product[] @relation("ProductCategory")
  subcategoryProducts Product[] @relation("ProductSubcategory")

  @@index([parentId, active, order])
  @@map("categories")
}

// ─── Product ──────────────────────────────────────────────────────────────────

model Product {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  description      String
  brand            String?
  ean              String?
  benefits         String?  @db.Text
  howToUse         String?  @db.Text
  composition      String?  @db.Text
  careInstructions String?  @db.Text
  packageContents  String?  @db.Text
  price            Decimal  @db.Decimal(10, 2)
  promotionalPrice Decimal? @db.Decimal(10, 2)
  stock            Int      @default(0)
  minStock         Int      @default(5)
  weight           Decimal  @default(0.3) @db.Decimal(10, 3)
  height           Decimal  @default(5)   @db.Decimal(10, 2)
  width            Decimal  @default(10)  @db.Decimal(10, 2)
  length           Decimal  @default(15)  @db.Decimal(10, 2)
  active           Boolean  @default(true)
  featured         Boolean  @default(false)
  isNew            Boolean  @default(true)
  soldCount        Int      @default(0)
  sku              String?
  blingId          String?  @unique
  importSource     ProductImportSource @default(MANUAL)
  enrichmentStatus ProductEnrichmentStatus @default(NOT_REQUIRED)
  publicationStatus ProductPublicationStatus @default(IMPORTED)
  searchTags       String[] @default([])
  researchSources  Json?
  researchNotes    String? @db.Text
  researchedAt     DateTime?
  importedAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  category   Category @relation("ProductCategory", fields: [categoryId], references: [id])
  categoryId String
  subcategory   Category? @relation("ProductSubcategory", fields: [subcategoryId], references: [id])
  subcategoryId String?

  images      ProductImage[]
  variations  ProductVariation[]
  cartItems   CartItem[]
  orderItems  OrderItem[]
  favorites   Favorite[]

  @@map("products")
}

enum ProductImportSource {
  MANUAL
  BLING
}

enum ProductEnrichmentStatus {
  NOT_REQUIRED
  PENDING_RESEARCH
  ENRICHED
  NEEDS_MANUAL_REVIEW
  MANUAL_REVIEWED
}

enum ProductPublicationStatus {
  IMPORTED
  PENDING_REVIEW
  APPROVED
  PUBLISHED
  HIDDEN
  MISSING_IMAGE
  MISSING_DESCRIPTION
}

// ─── ProductImage ─────────────────────────────────────────────────────────────

model ProductImage {
  id        String   @id @default(cuid())
  url       String
  alt       String?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String

  @@map("product_images")
}

// ─── ProductVariation ────────────────────────────────────────────────────────

model ProductVariation {
  id            String   @id @default(cuid())
  name          String
  value         String
  sku           String?
  imageUrl      String?
  stock         Int      @default(0)
  priceModifier Decimal  @default(0) @db.Decimal(10, 2)
  isDefault     Boolean  @default(false)
  order         Int      @default(0)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())

  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId  String
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@map("product_variations")
}

// ─── Cart ─────────────────────────────────────────────────────────────────────

model Cart {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId String   @unique

  items CartItem[]

  @@map("carts")
}

model CartItem {
  id         String   @id @default(cuid())
  quantity   Int
  unitPrice  Decimal  @db.Decimal(10, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  cart        Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  cartId      String
  product     Product  @relation(fields: [productId], references: [id])
  productId   String
  variation   ProductVariation? @relation(fields: [variationId], references: [id])
  variationId String?

  @@unique([cartId, productId, variationId])
  @@map("cart_items")
}

// ─── Order ────────────────────────────────────────────────────────────────────

model Order {
  id                   String        @id @default(cuid())
  orderNumber          String        @unique
  status               OrderStatus   @default(CRIADO)
  subtotal             Decimal       @db.Decimal(10, 2)
  shippingPrice        Decimal       @default(0) @db.Decimal(10, 2)
  discount             Decimal       @default(0) @db.Decimal(10, 2)
  total                Decimal       @db.Decimal(10, 2)
  shippingType         ShippingType
  shippingTrackingCode String?
  notes                String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  customer   Customer  @relation(fields: [customerId], references: [id])
  customerId String
  address    Address?  @relation(fields: [addressId], references: [id])
  addressId  String?
  coupon     Coupon?   @relation(fields: [couponId], references: [id])
  couponId   String?

  items   OrderItem[]
  payment Payment?
  statusHistory OrderStatusHistory[]

  @@map("orders")
}

model OrderItem {
  id            String   @id @default(cuid())
  productName   String
  productImage  String?
  variationName String?
  quantity      Int
  unitPrice     Decimal  @db.Decimal(10, 2)
  totalPrice    Decimal  @db.Decimal(10, 2)

  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId     String
  product     Product  @relation(fields: [productId], references: [id])
  productId   String
  variation   ProductVariation? @relation(fields: [variationId], references: [id])
  variationId String?

  @@map("order_items")
}

model OrderStatusHistory {
  id        String      @id @default(cuid())
  status    OrderStatus
  note      String?
  createdAt DateTime    @default(now())

  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId String

  @@map("order_status_history")
}

enum OrderStatus {
  CRIADO
  AGUARDANDO_PAGAMENTO
  PAGAMENTO_APROVADO
  EM_SEPARACAO
  PRONTO_PARA_RETIRADA
  SAIU_PARA_ENTREGA
  ENVIADO_CORREIOS
  ENTREGUE
  CANCELADO
}

enum ShippingType {
  CORREIOS
  MOTOTAXI
  RETIRADA
}

// ─── Payment ──────────────────────────────────────────────────────────────────

model Payment {
  id            String        @id @default(cuid())
  method        PaymentMethod
  status        PaymentStatus @default(AGUARDANDO)
  amount        Decimal       @db.Decimal(10, 2)
  gatewayId     String?
  gatewayData   Json?
  pixCode       String?       @db.Text
  pixExpiration DateTime?
  paidAt        DateTime?
  refundedAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  order   Order  @relation(fields: [orderId], references: [id])
  orderId String @unique

  @@map("payments")
}

enum PaymentMethod {
  PIX
  CARTAO_CREDITO
  BOLETO
}

enum PaymentStatus {
  AGUARDANDO
  PAGO
  RECUSADO
  CANCELADO
  REEMBOLSADO
}

// ─── Coupon ───────────────────────────────────────────────────────────────────

model Coupon {
  id           String      @id @default(cuid())
  code         String      @unique
  description  String?
  discountType DiscountType
  discountValue Decimal    @db.Decimal(10, 2)
  minOrderValue Decimal?   @db.Decimal(10, 2)
  maxUses       Int?
  usedCount     Int        @default(0)
  active        Boolean    @default(true)
  expiresAt     DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  orders Order[]

  @@map("coupons")
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

// ─── Favorite ─────────────────────────────────────────────────────────────────

model Favorite {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId  String

  @@unique([customerId, productId])
  @@map("favorites")
}

// ─── Notification ─────────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  body      String
  data      Json?
  read      Boolean          @default(false)
  sentAt    DateTime?
  createdAt DateTime         @default(now())

  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId String

  @@map("notifications")
}

enum NotificationType {
  PEDIDO_CONFIRMADO
  PAGAMENTO_APROVADO
  EM_SEPARACAO
  PRONTO_RETIRADA
  SAIU_ENTREGA
  ENTREGUE
  PROMOCAO
  SISTEMA
}

// ─── StoreSettings ────────────────────────────────────────────────────────────

model StoreSettings {
  id                  String   @id @default(cuid())
  storeName           String   @default("KA Bijoux")
  storeAddress        String   @default("")
  storeCity           String   @default("Itaúna")
  storeState          String   @default("MG")
  storeZipCode        String   @default("")
  storePhone          String   @default("")
  storeWhatsapp       String?
  storeEmail          String   @default("")
  storeHours          String?
  mototaxiPrice       Decimal  @default(10.00) @db.Decimal(10, 2)
  mototaxiEnabled     Boolean  @default(true)
  correiosEnabled     Boolean  @default(true)
  storePickupEnabled  Boolean  @default(true)
  logoUrl             String?
  bannerUrls          String[] @default([])
  updatedAt           DateTime @updatedAt

  @@map("store_settings")
}

// Stories da home

model StoryGroup {
  id            String      @id @default(cuid())
  title         String
  coverImageUrl String?
  isActive      Boolean     @default(true)
  sortOrder     Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  items StoryItem[]

  @@index([isActive, sortOrder])
  @@map("story_groups")
}

model StoryItem {
  id           String        @id @default(cuid())
  type         StoryItemType
  mediaUrl     String
  duration     Int           @default(5)
  text         String?
  buttonText   String?
  linkUrl      String?
  isActive     Boolean       @default(true)
  sortOrder    Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  storyGroup   StoryGroup @relation(fields: [storyGroupId], references: [id], onDelete: Cascade)
  storyGroupId String

  @@index([storyGroupId, isActive, sortOrder])
  @@map("story_items")
}

enum StoryItemType {
  IMAGE
  VIDEO
}
