# ═══════════════════════════════════════════════════════════════
#  KA Bijoux — Variáveis de Ambiente
#  Copie este arquivo para .env e preencha os valores reais.
#  NUNCA suba o arquivo .env para o repositório.
# ═══════════════════════════════════════════════════════════════

# ─── Banco de Dados (Supabase) ──────────────────────────────────────────────
#
# Ambas as URLs são obtidas no Supabase:
#   Dashboard → Settings → Database → Connection string
#
# DATABASE_URL → use a URL do "Connection Pooler" (porta 6543, modo Transaction)
#   Formato: postgresql://postgres.XXXX:SENHA@aws-0-XX-XXXX.pooler.supabase.com:6543/postgres?pgbouncer=true
#
# DIRECT_URL → use a URL "Direct connection" (porta 5432)
#   Formato: postgresql://postgres:SENHA@db.XXXX.supabase.co:5432/postgres
#
DATABASE_URL="postgresql://postgres.XXXX:SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:SENHA@db.XXXX.supabase.co:5432/postgres"

# ─── Autenticação / JWT ─────────────────────────────────────────────────────
#
# Gere strings aleatórias seguras (mínimo 32 caracteres):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
NEXTAUTH_SECRET="gere-uma-string-aleatoria-segura-aqui"
NEXTAUTH_URL="https://ka-bijoux.vercel.app"

JWT_SECRET="outra-string-aleatoria-segura-para-o-app-mobile"
JWT_EXPIRES_IN="7d"

# ─── URL pública do app ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://ka-bijoux.vercel.app"

# ─── Mercado Pago ────────────────────────────────────────────────────────────
# Deixar vazio por enquanto — integração será feita em etapa futura.
# Obtenha em: https://www.mercadopago.com.br/developers/panel
#
MERCADO_PAGO_ACCESS_TOKEN=""
MERCADO_PAGO_PUBLIC_KEY=""
MERCADO_PAGO_WEBHOOK_SECRET=""

# ─── Melhor Envio (Correios) ─────────────────────────────────────────────────
# Deixar vazio por enquanto — integração será feita em etapa futura.
# Obtenha em: https://melhorenvio.com.br/painel/gerenciar/tokens
#
MELHOR_ENVIO_TOKEN=""
MELHOR_ENVIO_SANDBOX="true"

# ─── Upload de Imagens (Cloudinary) ─────────────────────────────────────────
# Opcional para produção. Obtenha em: https://cloudinary.com
#
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ─── Expo Push Notifications ─────────────────────────────────────────────────
# Obtenha em: https://expo.dev/accounts/SEU_USUARIO/settings/access-tokens
#
EXPO_ACCESS_TOKEN=""

# ─── Desenvolvimento local ───────────────────────────────────────────────────
NODE_ENV="development"
