{
  "cli": {
    "version": ">= 10.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://ka-bijoux-backend.vercel.app",
        "EXPO_PUBLIC_SITE_URL": "https://kabijoux.com.br"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://ka-bijoux-backend.vercel.app",
        "EXPO_PUBLIC_SITE_URL": "https://kabijoux.com.br"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://ka-bijoux-backend.vercel.app",
        "EXPO_PUBLIC_SITE_URL": "https://kabijoux.com.br"
      }
    }
  },
  "update": {
    "channel": "production"
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "internal"
      }
    }
  }
}
